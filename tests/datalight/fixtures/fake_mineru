#!/usr/bin/env bash
# Mimic: mineru -p IN -o OUT -b B --source local
set -euo pipefail
P=""; O=""; B=""
while [ $# -gt 0 ]; do
  case "$1" in
    -p) P="$2"; shift 2 ;;
    -o) O="$2"; shift 2 ;;
    -b) B="$2"; shift 2 ;;
    --source) shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done
[ -n "$P" ] && [ -n "$O" ] && [ -n "$B" ]
f="$(basename "$P")"
stem="${f%.*}"
mkdir -p "${O}/${stem}/${B}"
md="${O}/${stem}/${B}/${stem}.md"
printf '# fake\n' > "$md"
exit 0
